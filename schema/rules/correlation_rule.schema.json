{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/rules/correlation_rule.schema.json",
  "title": "Analyst Rule Schema",
  "type": "object",
  "required": [
    "title",
    "rule_type",
    "id",
    "status",
    "description",
    "references",
    "author",
    "date",
    "tags",
    "correlation",
    "fields",
    "falsepositives",
    "level"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "rule_type": {
      "type": "string",
      "const": "analyst"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "status": {
      "type": "string",
      "enum": ["stable", "test", "experimental", "deprecated", "unsupported"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          }
        ]
      }
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "correlation": {
      "type": "object",
      "required": [
        "type",
        "rules",
        "group-by",
        "timespan",
        "condition"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "group-by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timespan": {
          "type": "string",
          "pattern": "^[0-9]+[smhd]$"
        },
        "condition": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "oneOf": [
              { "type": "number" },
              { "type": "string" },
              { "type": "boolean" }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "falsepositives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "level": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "critical"]
    },
    "x_query": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
