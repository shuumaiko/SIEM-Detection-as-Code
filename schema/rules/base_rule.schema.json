{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/rules/base_rule.schema.json",
  "title": "Detection Base Rule Schema",
  "type": "object",
  "required": [
    "title",
    "name",
    "id",
    "status",
    "description",
    "references",
    "author",
    "date",
    "modified",
    "tags",
    "logsource",
    "detection"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "logsource": {
      "type": "object",
      "required": [
        "category",
        "product",
        "service"
      ],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "detection": {
      "type": "object",
      "required": [
        "condition"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" }
                    ]
                  },
                  "minItems": 1
                }
              ]
            }
          },
          {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                { "type": "object" }
              ]
            }
          },
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  },
  "additionalProperties": false
}

