{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/rules/base_rule.schema.json",
  "title": "Detection Rule Schema",
  "type": "object",
  "required": [
    "title",
    "id",
    "status",
    "description",
    "references",
    "author",
    "date",
    "tags",
    "logsource",
    "detection"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "rule_type": {
      "type": "string",
      "enum": ["detection", "detection_base", "base"]
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          }
        ]
      }
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "logsource": {
      "type": "object",
      "anyOf": [
        {
          "required": ["category"]
        },
        {
          "required": ["product"]
        },
        {
          "required": ["service"]
        }
      ],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "detection": {
      "type": "object",
      "required": [
        "condition"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                { "type": "null" },
                {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" },
                      { "type": "object" },
                      { "type": "null" }
                    ]
                  },
                  "minItems": 1
                },
                { "type": "object" }
              ]
            }
          },
          {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" },
                { "type": "object" },
                { "type": "null" }
              ]
            }
          },
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" },
          { "type": "null" }
        ]
      }
    },
    "falsepositives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "level": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "critical"]
    },
    "x_query": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "rule_type": {
            "const": "base"
          }
        },
        "required": ["rule_type"]
      },
      "then": {
        "properties": {
          "level": {
            "const": "informational"
          }
        }
      }
    }
  ]
}
