{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/tenants/logsource.schema.json",
  "title": "Tenant Logsource Schema",
  "type": "object",
  "required": [
    "schema_version",
    "device_id",
    "service"
  ],
  "properties": {
    "schema_version": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "number" }
      ]
    },
    "device_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "service": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["service_id", "category", "log_type", "enabled"],
        "properties": {
          "service_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "log_type": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
