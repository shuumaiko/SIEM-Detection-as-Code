{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/tenants/detection_filter_override.schema.json",
  "title": "Tenant Detection Filter Override Schema",
  "type": "object",
  "required": [
    "tenant_id",
    "rule_id",
    "rule_name",
    "author",
    "date",
    "description",
    "detection_filters",
    "append_condition"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "rule_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "rule_name": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "detection_filters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "$ref": "#/$defs/condition_value"
        }
      }
    },
    "append_condition": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "condition_value": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition_value"
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/condition_value"
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
