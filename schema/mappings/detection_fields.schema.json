{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/mappings/detection_fields.schema.json",
  "title": "Detection Field Mapping Schema",
  "type": "object",
  "required": [
    "schema_version",
    "mapping_type",
    "logsource",
    "fields"
  ],
  "properties": {
    "schema_version": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "number" }
      ]
    },
    "mapping_type": {
      "type": "string",
      "const": "detection_fields"
    },
    "logsource": {
      "type": "object",
      "required": [
        "category",
        "product",
        "service"
      ],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "canonical_field",
          "source_fields"
        ],
        "properties": {
          "canonical_field": {
            "type": "string",
            "pattern": "^canonical\\.[A-Za-z0-9_.-]+$"
          },
          "source_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
