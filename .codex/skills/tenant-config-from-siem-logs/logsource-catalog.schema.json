{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": ".codex/skills/tenant-config-from-siem-logs/logsource-catalog.schema.json",
  "title": "Tenant Config Skill Logsource Catalog Reference",
  "type": "object",
  "required": ["schema_version", "catalog_entries"],
  "properties": {
    "schema_version": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "number" }
      ]
    },
    "catalog_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "catalog_logsource",
          "suggested_category",
          "suggested_service",
          "dataset_id_pattern"
        ],
        "properties": {
          "catalog_logsource": {
            "type": "string",
            "minLength": 1
          },
          "suggested_category": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "suggested_service": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "dataset_id_pattern": {
            "type": "string",
            "minLength": 1
          },
          "device_types": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          },
          "repo_examples": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            }
          },
          "match_hints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
